{
  "name": "wifi-time-tracker",
  "version": "1.0.6",
  "description": "Track how long your computer stays connected to WiFi",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:all": "electron-vite build && electron-builder --win --mac"
  },
  "build": {
    "appId": "com.wifitimetracker.app",
    "productName": "WiFi Time Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/icons/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/build/icon.png",
      "artifactName": "${productName} Setup.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/build/icon.png",
      "artifactName": "${productName}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WiFi Time Tracker"
    }
  },
  "dependencies": {
    "chart.js": "^4.4.7",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
